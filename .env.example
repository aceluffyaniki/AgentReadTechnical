# ============================================================
# AgenTrading — Environment Variables
# Copy file ini ke .env dan isi dengan nilai kamu sendiri
# ============================================================

# ---- Database ----
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@localhost:5432/agentrading?sslmode=disable

# ---- Go Backend ----
BACKEND_PORT=8080
GIN_MODE=debug  # debug | release

# ---- Python Scraper Microservice ----
SCRAPER_URL=http://localhost:8001

# ---- Google Gen AI (Gemini API) ----
# Dapatkan API key di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview
# Alternatif lebih murah/cepat:
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ---- Explorer APIs (opsional untuk analisa on-chain) ----
BSCSCAN_API_KEY=your_bscscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
HELIUS_API_KEY=your_helius_api_key
SOLSCAN_API_KEY=your_solscan_api_key

# ---- Telegram Alerts (opsional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Cost Guard ----
MAX_PROMPT_TOKENS=20000
SCAM_ALERT_THRESHOLD=70
